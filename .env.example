# Brevo (Sendinblue) API Configuration
# Obtenez votre clé API sur: https://app.brevo.com/settings/keys/api

# Clé API Brevo (obligatoire)
BREVO_API_KEY=your_brevo_api_key_here

# Email de l'expéditeur (doit être vérifié dans Brevo)
BREVO_SENDER_EMAIL=noreply@kenomi.com

# Email du destinataire (où les messages seront envoyés)
BREVO_RECIPIENT_EMAIL=contact@kenomi.com
